function goLoginChk(){
	var id = $("#id");
	var pwd = $("#pwd");
	jLang = $("input[type=radio][name=lang]:checked").val();
	if(id.val() == ""){
		if(deviceGb == "W"){
			fnAlert(fnLoginMessage(0), function(){
				fnObjFocus(id);
			},jLang);
		}else{
			alert(fnLoginMessage(0));
			id.focus();
		}
		return;
	}
	if(pwd.val() == ""){
		if(deviceGb == "W"){
			fnAlert(fnLoginMessage(1), function(){
				fnObjFocus(pwd);
			},jLang);
		}else{
			alert(fnLoginMessage(1));
			pwd.focus();
		}
		return;
	}
	NetFunnel_Action({action_id: "login",popup_target:top.Main, use_frame_block:true},goLogin);
	
}
function goLogin(){
	$.ajax({
		type: "POST",
		url: "/login?attribute=loginChk&fake=" + Date.now(),
		data:$("#loginForm").serialize(),
		dataType : "json",
		//jsonp : "callback",
		//async:false,
		success: function(data) {
			NetFunnel_Complete();
			var msg = data.msg;
			var code = data.code;
			var token	= data.token;			
			if(code == "200" || code == "201"){
				top.setToken(token);
				menuId 	= "menu_sugang";
				menuUrl	= "/sugang?attribute=sugangMain";
				localStorage.setItem('menu',JSON.stringify({'menuId':menuId, 'menuUrl': menuUrl,'target':undefined}));
				document.loginForm.action = "" +context + "/core?attribute=coreFrame&fake="+Date.now();
				if(code == "201"){
					var fnNext = function(){
						document.loginForm.submit();
					}
					fnAlert(msg,fnNext);
				}else{
					document.loginForm.submit();
				}
			}else{						
				if(deviceGb == "W"){
					fnAlert(msg);
				}else{
					alert(msg);
				}
				return;	
			}
		},
		beforeSend: function() {
			$('.wrap-loader').css('display', 'inline-block');
		},	
		complete: function() {
			$('.wrap-loader').css('display', 'none');
		},
		error: function(req, status, error){
			NetFunnel_Complete();
			alert(error);
		}
	});
}
function fnMenuLoad(menuUrl, menuId, target){	
	if(target != undefined && target != 'undefined' && target != '' && target != 'init'){
		windowOpen(menuUrl,'pwdchangestudent','720', '530');
	}else{
		localStorage.setItem('menu',JSON.stringify({'menuId':menuId, 'menuUrl': menuUrl,'target':target}));
		document.loginForm.action = context + "/core?attribute=coreFrame&flagx=X&fake="+Date.now();
		document.loginForm.submit();
	}
}
