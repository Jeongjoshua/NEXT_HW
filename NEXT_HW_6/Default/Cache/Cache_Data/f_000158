function sharebetCaochSNS(data, shareType){
//	var betCoachArea = $(this).parents(".betCoachArea");
//	var prediction = betCoachArea.data();
//	console.log("check sns data::",data);
	var calculatorHitAmt = 0;
	var prediction = data.prediction;

	var allotWin  = betCoach.util.numFormatCase("rateAllot",prediction.allotWin,".");
	var allotDraw = betCoach.util.numFormatCase("rateAllot",prediction.allotDraw,".");
	var allotLoss = betCoach.util.numFormatCase("rateAllot",prediction.allotLoss,".");
	var topAllot = allotWin > allotDraw ? (allotWin > allotLoss ? allotWin : allotLoss) : (allotDraw > allotLoss ? allotDraw : allotLoss);
	
	if(prediction.simulResult== "1"){//승
		calculatorHitAmt = 1000 * Number(allotWin);
	}else if(prediction.simulResult== "2"){//무
		calculatorHitAmt = 1000 * Number(allotDraw);
	}else if(prediction.simulResult== "3"){//패
		calculatorHitAmt = 1000 * Number(allotLoss);
	}else if(prediction.simulResult== "4"){//해당데이터없음
		calculatorHitAmt = 0;
	}else if(prediction.simulResult== "5"){//접전
		calculatorHitAmt = 1000 * Number(topAllot);
	}
	
	var loginId = login.getLoginInfo().id;
	var loginName = login.getLoginInfo().name;
//	//TODO : test data setting
//	if(loginId=="") {
//		loginId= "testId"; loginName="충*신"; 
//	}
//	var rowIdx = $(betCoachArea).find(".bc-sns-row-idx").text();
	var rowIdx = data.rowIdx; 						//프로토 승부식, 축구토토 승무패인경우 =>betGameType = "G"
	var tabIdx = recordTabId[recordTabId.length-1]; //맞대결정보 =>betGameType = "D"
	var betGameType="G";
	if(rowIdx == undefined){
		rowIdx = tabIdx;
		betGameType = "D";
	}
	var snsInParam = {
		gmId : prediction.betCoachGame.gmId.toString(), 
		gmTs : prediction.betCoachGame.gmTs.toString(), 
		gmOsidTs : prediction.betCoachGame.gmOsidTs.toString(), 
		gmSeq : prediction.betCoachGame.gameSeq,
		gmNm : prediction.betCoachGame.gameName.replace(/ /g,''),
		shareType : shareType,
		predResult : prediction.simulResult,
		shareUserId : loginId,
		shareUserNm : loginName,   
		hitAmt : calculatorHitAmt,
		rowIdx : rowIdx,
		betGameType : betGameType
	};
	console.log("check snsInParam ::",snsInParam);
	betCoach.shareSNS(snsInParam);
}