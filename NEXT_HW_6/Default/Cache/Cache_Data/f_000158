	// 투표지 적용 이벤트.
	$(document).on("click", ".bc-btn-slip", function(e) {
		if(!isLogin){
			// BF0132 confirm 
			if (confirm(getMessage("BF0133"))) { // 로그인 후 My Bet코치로 이동하실 수 있습니다.로그인하겠습니까?
				openLoginPop("betCoach.util.reload");
			}
			return; 
		} 
		
		var betCoachArea = $(this).parents(".betCoachArea");
		var betCoachAreaData = betCoachArea.data();
		var row = betCoachAreaData.rowIdx;	// Parent에서 받은 rowIdx
		
		var bcAllotArea = $(betCoachArea).find(".bc-allot-area").find(".bc-btn-allot");
		var col = 1;						// 벳코치에서 사용자가 선택한 승 무 패 승:1,무:2,패:3
		var selectorClass = "";
		$(bcAllotArea).each(function(i) {
			var selector = $(this);
			var voteIndex = selector.context.className.indexOf("on");
			if(voteIndex != -1){
				// console.log("check selector::",selector.context.className);
				// console.log("check selector split::",selector.context.className.split(" ")[0]);
				selectorClass = selector.context.className.split(" ")[0];
				if(selectorClass=="winBtn"){
					col = 1;
				}else if(selectorClass=="drawBtn"){
					col = 2;
				}else if(selectorClass=="lossBtn"){
					col = 3;
				}
			}
		}); 
		var checkRateParam ={
			gmTs : betCoachAreaData.prediction.betCoachGame.gmTs,
			handiType : 0,
			gameSeq : betCoachAreaData.prediction.betCoachGame.gameSeq,
			seqNo: betCoachAreaData.prediction.betCoachGame.seqNo
		};
		// 벳코치 투표지 적용하기 : 배당률 사용가능 여부 체크
		betCoach.checkRateInfo(checkRateParam).done(function(serverResponseData){
			// console.log("check checkRateInfo serverResponseData::",serverResponseData);
			// validatePutSlip 시작
			/* 투표지 담기 처리자 */
			if( betCoachAreaData.gmId == "G101"){//프로토 승부식인 경우만 배당률이 있기 때문에 진행
				var validatePutSlip = betCoach.util.validatePutSlip(betCoachAreaData.prediction, serverResponseData.checkResult);
				// $(betCoachArea).find(".bc-btn-slip").attr("disabled", true);
				// $(betCoachArea).find(".bc-btn-slip").css({"color":"#999", "cursor":"default"});
				betLoader.end();
				// console.log("check validatePutSlip ::",validatePutSlip);
			}
			betCoachAreaData.prediction.checkMyPick = col;
			var putSlipParam = {
				prediction : betCoachAreaData.prediction, 
				checkResult : serverResponseData,
				bcReqClCd : betCoachAreaData.bcReqClCd
			}; 
			//벳코치 투표지 적용하기 : insert Query3개 사용 Transaction 로직 시작
			betCoach.predictionJoin(putSlipParam).done(function(response){
				 // console.log("check putSlip response ::", response);
				if(response.pred_seq !=null || response.pred_seq != undefined){
					// console.log('check setBetcoachSlipMarking param ::',row+"||"+col);
					slipUtil.setBetcoachSlipMarking(row, col);	//Parent 페이지에 사용자 투표지 적용결과 Return
					
				}
				
			});
		});
	});

