	$(document).on("change", "input[name='hitRateSeperator']", function(e){
		 
		var seperator = $("input[name='hitRateSeperator']:checked").val();
		
		var area = $(this).parents(".bc-hr-search-area");
		var start = $(area).find(".bt-hr-start");
		var end = $(area).find(".bt-hr-end");
		
		var startVal = $(start).val();
		var endVal = $(end).val();
		
		if(seperator == "monthly"){
			$(start).hide().betDatePicker('destroy').toggleClass("bt-hr-start");
			$(end).hide().betDatePicker('destroy').toggleClass("bt-hr-end");

			var monthStart = $(area).find(".bt-hr-monthly-start");
			$(monthStart).betMonthPicker().addClass("bt-hr-start").show();
			betCoach.util.checkDisplay($(monthStart).parent().find(".ui-monthpicker-trigger"));
			$(monthStart).data("beforeChange", startVal);
			
			var monthEnd = $(area).find(".bt-hr-monthly-end");
			$(monthEnd).betMonthPicker().addClass("bt-hr-end").show();
			betCoach.util.checkDisplay($(monthEnd).parent().find(".ui-monthpicker-trigger"));
			$(monthEnd).data("beforeChange", endVal);
			 
			$(area).find(".ui-datepicker-trigger").hide();
			$(area).find(".bc-hit-rate-con-txt").text("최대 3년까지 검색 가능합니다.");
		}  
		else{
			$(start).hide().betMonthPicker('destroy').toggleClass("bt-hr-start");
			$(end).hide().betMonthPicker('destroy').toggleClass("bt-hr-end");
			
			var dayStart = $(area).find(".bt-hr-daily-start");
			$(dayStart).betDatePicker().addClass("bt-hr-start").show();
			betCoach.util.checkDisplay($(dayStart).parent().find(".ui-datepicker-trigger"));
			
			var dayEnd = $(area).find(".bt-hr-daily-end");
			$(dayEnd).betDatePicker().addClass("bt-hr-end").show();
			betCoach.util.checkDisplay($(dayEnd).parent().find(".ui-datepicker-trigger"));
			
			$(area).find(".ui-monthpicker-trigger").hide();
			$(area).find(".bc-hit-rate-con-txt").text("최대 1개월까지 검색 가능합니다.");
			
		}
		
	});
