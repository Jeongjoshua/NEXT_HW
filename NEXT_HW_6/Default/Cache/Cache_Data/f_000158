$(function(){
	// 시뮬레이션 바 점 클릭 이벤트
	$(document).on("click", ".bc-dot-btn", function(e) {
		// 직접설정 클릭으로 변경?
		var weight = parseInt($(this).val()); 
		//(접근성)pub js코드 추가
		var $self = $(this);
		var perNum = $self.text();
		// console.log("check this perNum",perNum);
		$self.closest(".graphBox").find(".bar > span").css('width', perNum);
		$self.closest(".dotList").find("button").removeAttr("title");
		$self.attr("title", "선택됨");

		$(this).parents(".graphBox").find(".bc-data-percent").css("width", weight + "%");
		
		var template = $(this).parents(".betCoachArea");
		var simulBar = $(this).parents(".bc-data-sb");
		var prediction = template.data().prediction;
		var weightPredCode = $(simulBar).find(".bc-popup-btn").data("pred-cd");
		var param = {
			prediction : prediction, 
			predCode : weightPredCode, 
			weight: weight, 
			bcReqClCd : template.data().bcReqClCd
		};
		
		betCoach.barChange(param).done(function(response){
			$(template).data(response);  
			betCoach.util.simulBarWeightConvert(template, response.prediction.weightList); 
			
			betCoachDrawer.noDataGraph(template, response.prediction);
			betCoachDrawer.donut(template, response.prediction);
			betCoachDrawer.vote(template, response.prediction); 
			
			var btns = $(template).find(".bc-data-ws-btn")
			$(btns).removeClass("on");
			$(btns).each(function(i) {
				var selector = $(this);
				var span = $(selector).find(".bc-data-ws");
				if(span.text()=="직접설정"){ 
					$(selector).addClass("on").attr('title', '선택됨');
					
				}
			});
		});

	});

	// 가중치 설정 버튼 클릭 : 안정 중립 모험 직접설정 버튼
	$(document).on("click", ".bc-data-ws-btn", function(e) {
		var selector = $(this);
		// console.log("check selector :", $(selector));
		$(selector).parent().find("button").removeClass("on");
		var weight = $(selector).data();
		
		var res = $(selector).parents(".betCoachArea").data();
		var param = {adminWeight : weight, prediction : res.prediction, bcReqClCd : res.bcReqClCd};
		// console.log("check 가중치 설정 버튼 클릭 adminWeightChange param ::",param);
		betCoach.adminWeightChange(param).done(function(response){
			var template = $(selector).parents(".betCoachArea");
			$(template).data(response); 
			betCoach.util.simulBarWeightConvert(template, response.prediction.weightList);

			betCoachDrawer.noDataGraph(template, response.prediction);
			betCoachDrawer.donut(template, response.prediction);
			betCoachDrawer.vote(template, response.prediction);
			selector.addClass("on").attr('title', '선택됨');
		});
	});
	// 시뮬레이션 바 Info 버튼 클릭 이벤트 (팝업 호출)
	$(document).on("click", ".bc-popup-btn", function(e) { 
		var selector = e.target;

		var weightName = $(selector).data("weight"); 

		var weightPredCode = $(selector).data("pred-cd");
		var jspFileName = weightPredCode.toLowerCase();
		var res = $(selector).parents(".betCoachArea").data();
		var weightList = res.prediction.weightList;
		var sourceData = null;
		for (var i in weightList){
			var WL = weightList[i]; 
			if(weightPredCode == WL.predictionCode){
				sourceData = JSON.parse(JSON.stringify(WL));
			}
		}
		var popupSize;
		var smallPopList = ["sc003","sc004","sc007","bs002","bs003","bs004","bk003","bk007","vl007"];
		var largePopList = ["bs006","bs007","vl004"];
		var largeBPopList = ["vl002"]; 
		for(var i in smallPopList){
			if(jspFileName == smallPopList[i]){
				// console.log("check smallPopList name ::",jspFileName+"||"+smallPopList[i]);
				popupSize = "small";
			}
		}
		for(var i in largePopList){
			if(jspFileName == largePopList[i]){
				// console.log("check largePopList name ::",jspFileName+"||"+largePopList[i]);
				popupSize = "large";
			}
		}
		for(var i in largeBPopList){
			if(jspFileName == largeBPopList[i]){
				// console.log("check largeBPopList name ::",jspFileName+"||"+largeBPopList[i]);
				popupSize = "largeB";
			}
		}
		popupSize = popupSize=="small"? popupSize : popupSize=="large"? popupSize : popupSize=="largeB"? popupSize :"base";
		var param = {
			title : weightName,
			weight : sourceData,
			res : res,
			uri : "/"+ jspFileName,
			size : popupSize
		}
		betCoach.openPop(param);
	});
