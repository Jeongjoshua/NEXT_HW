<script>
	var offWinrst = {};
	
	//QR코드 조회
	offWinrst.serial = ''.trim().toUpperCase();
	
	$(function() {
		offWinrst.reset();
		
		$("#btn_inqOffWinrst").bind("click", function() {
			offWinrst.inq();
		});
		$("#btn_reset").bind("click", function() {
			offWinrst.reset();
		});
		$('#ibx_serial_1, #ibx_serial_2, #ibx_serial_3, #ibx_serial_4').bind('keyup', function(ev) {
			var value = $(this).val().replace(/[^0-9A-Za-z]/g, '');
			$(this).val(value);
		});
		//일부 android 기기에서 maxlength 적용 안되는 경우가 있는듯 해서 추가
		$('#ibx_serial_1, #ibx_serial_2, #ibx_serial_3, #ibx_serial_4').bind('keypress', function(ev) {
			if(this.value.length >= $(this).attr('maxlength')) return false;
		});
		
		if(offWinrst.serial.length >= 15) {
			$('#ibx_serial_1').val(offWinrst.serial.substr(0, 4));
			$('#ibx_serial_2').val(offWinrst.serial.substr(4, 4));
			$('#ibx_serial_3').val(offWinrst.serial.substr(8, 4));
			$('#ibx_serial_4').val(offWinrst.serial.substr(12, 3));
			offWinrst.inq();
		}
	});
	
	/**
	 * 오프라인 적중결과 화면 초기상태로 리셋
	 */
	offWinrst.reset = function() {
		$("#div_txtBox .iconText").html('&lsquo;적중결과 처리중&rsquo;에는 영수증 조회가 불가능합니다.<br>적중결과 발표 이후에 조회하시기 바랍니다.');
		$('#div_txtBox .iconText').show();
		$("#div_txtBox").show();
		$("#div_offWinrst").hide();
		$("#btn_reset").hide();
		$("#div_onTest").hide();
		$("#div_txtBox .offNumBox input").val('');
		$("#div_txtBox .offNumBox input").prop('disabled', false);
		$("#btn_inqOffWinrst").prop('disabled', false);
	}
	
	/**
	 * 오프라인 적중결과 조회 후 화면 공통 이벤트
	 * @param 조회실패 여부
	 */
	offWinrst.onInqEvent = function(flag) {
		$("#div_txtBox .offNumBox input").prop('disabled', true);
		$("#btn_inqOffWinrst").prop('disabled', true);
		$("#btn_reset").show();
		//조회 실패시 적중테이블 show 안함
		if(!flag) $("#div_offWinrst").show();
	}
	
	/**
	 * 오프라인 적중결과 데이터 조회
	 */
	offWinrst.inq = function() {
		var serial1 = $('#ibx_serial_1').val().trim().toUpperCase();
		var serial2 = $('#ibx_serial_2').val().trim().toUpperCase();
		var serial3 = $('#ibx_serial_3').val().trim().toUpperCase();
		var serial4 = $('#ibx_serial_4').val().trim().toUpperCase();
		var fullSerial = serial1 + serial2 + serial3 + serial4;
		
		if(fullSerial.length < 15) {
			alert('투표권 고유번호가 입력되지 않았습니다.\n투표권을 입력해 주세요.');			
			if(serial1.length < 4){
				$('#ibx_serial_1').focus();
			} else if(serial2.length < 4){
				$('#ibx_serial_2').focus();
			} else if(serial3.length < 4){
				$('#ibx_serial_3').focus();
			} else if(serial4.length < 3){
				$('#ibx_serial_4').focus();
			}
			return;
		}
		requestClient.requestPostMethod('/gamebuy/winrst/inqWinrstOffline.do',{ serial : fullSerial }, false, offWinrst.inqCallback);
	}
	
	/**
	 * 오프라인 적중결과 화면 draw
	 * @param 조회 데이터
	 */
	offWinrst.draw = function(data) {
		var saleStatusCode = {
			0 : '미판매',
			1 : '판매중', 
			10 : '적중안됨',
			21 : '적중',
			22 : '환불',
			31 : '적중금 환급기간 만료',
			32 : '환불금 지불기간 만료',
			91 : '취소처리'
		};
		var winOff = data.result;
		winOff.ucSaleStatus = Number(winOff.ucSaleStatus); 
		if(winOff.ucSaleStatus == 0) {
			$('#div_txtBox .iconText').html('&lsquo;적중결과 처리중&rsquo;이거나 투표권 번호가 정확하지 않을 경우 영수증 조회가 불가능합니다.');
			offWinrst.onInqEvent(true);
		} else {
			var tmp = '';
			switch(winOff.ucSaleStatus) {
				case 1: 
				case 10:
				case 22:
				case 32:
				case 91:
					$('#tr_hitInfo').hide();
					
					tmp = '<th scope="row"><span class="dot">총투표금액</span></th>';
					tmp += '<td colspan="3">'+ betmanOnlineFront.setNumberComma(winOff.llSalePrice) +'원</td>';
					$('#tr_amtInfo').html(tmp);
					break;
				case 21:
				case 31:
					if(winOff.gmId == 'G101' || winOff.gmId == 'G102') {
						tmp = '<th scope="row"><span class="dot">적중결과</span></th>';
						tmp += '<td colspan="3">적중</td>';
					} else {
						var rankTxt = winOff.gmTypeCd == 'Victory' && winOff.ucRanking && winOff.ucRanking != '당첨' ? '('+ winOff.ucRanking +')' : '';
						tmp = '<th scope="row"><span class="dot">적중결과</span></th>';
						tmp += '<td>적중'+ rankTxt +'</td>';
						tmp += '<th scope="row"><span class="dot">적중 투표매수</span></th>';
						tmp += '<td>'+ winOff.uiPrizeNum +'</td>';
					}
					$('#tr_hitInfo').html(tmp);
					$('#tr_hitInfo').show();
					
					tmp = '<th scope="row"><span class="dot">총투표금액</span></th>';
					tmp += '<td>'+ betmanOnlineFront.setNumberComma(winOff.llSalePrice) +'원</td>';
					tmp += '<th scope="row"><span class="dot">환급/환불금액</span></th>';
					tmp += '<td>'+ betmanOnlineFront.setNumberComma(winOff.llPrize) +'원</td>';
					$('#tr_amtInfo').html(tmp);
					break;
				default : 
					return;
			}
			$('#tr_saleInfo td strong').html(saleStatusCode[winOff.ucSaleStatus]);
			$('#tr_gmInfo td:eq(0)').html(winOff.szGameName +' '+ winOff.uiProdTs +'회차');
			var saleTime = new Date(
					winOff.stSaleTime.substr(0, 4) + '/' + //year
					winOff.stSaleTime.substr(4, 2) + '/' + //month
					winOff.stSaleTime.substr(6, 2) + ' ' + //date
					winOff.stSaleTime.substr(8, 2) + ':' + //hour
					winOff.stSaleTime.substr(10, 2)+ ':' + //min
					winOff.stSaleTime.substr(12, 2));      //sec
			$('#tr_gmInfo td:eq(1)').html(betmanOnlineFront.getDateFullFormatDayOfWeek(saleTime, 'y-mm-dd', ':'));
			offWinrst.onInqEvent();
		}
		$('#div_txtBox .iconText').hide();
	}
	
	/**
	 * 오프라인 적중결과 데이터 조회 콜백
	 * @param Map 오프라인 적중결과
	 */
	offWinrst.inqCallback = function(data) {
		if(!data.result) {
			if(data.message == 'DISCONNECT') {
				var dc = data.disconnect;
				$('#div_onTest p:eq(0)').html(betmanOnlineFront.unescapeString(dc.INFRM_MSG_CTT));//오프라인 투표권 시스템의 품질 향상을 위한, 시스템 점검 작업으로 인하여,<br>오프라인 투표권 적중결과 조회가 불가능하오니, 양해 부탁 드립니다.
				$('#div_onTest p:eq(1)').html('<span class="fwb">점검 일시</span> : '+ dc.ISOL_STA_DTM +' ~ '+ dc.ISOL_END_DTM);
				$('#div_txtBox').hide();
				$('#div_onTest').show();
			} else { //FAIL
				$('#div_txtBox .iconText').html('&lsquo;적중결과 처리중&rsquo;이거나 투표권 번호가 정확하지 않을 경우 영수증 조회가 불가능합니다.');
			}
			offWinrst.onInqEvent(true);
		} else {
			offWinrst.draw(data);
		}
	}
</script>
	
