<script>
function detectIE(){
	var isIE = false;
	var userAgent = window.navigator.userAgent;
	
	var oldIE = userAgent.indexOf('MSIE ');
	var newIE = userAgent.indexOf('Trident/');
	
	if((oldIE > -1 )|| (newIE > -1 )){
		isIE = true;
	}
	
	return isIE;
}
