	});
	
	popupCloseBtn.addEventListener('keydown',  function(event) {
		if(event.key === 'Enter'){
			popupClose();
		}
	});
	
	// 셀프테스트 이동(새탭)
	document.getElementById('selfTestBtn').addEventListener('click',  function() {
