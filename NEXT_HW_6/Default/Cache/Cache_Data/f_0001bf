/**
 * 목록조회 그리드 최초 생성 함수
 */
function initWinrstList() {
	$('#sbx_gmType').selectmenu('refresh');
	$('#sbx_gmCase').selectmenu('refresh');
	
	var cols = [
		{
			data : "GM_NM", //표시할 데이터명
			title : "게임명",
			orderable : false,
			render : function(data, type, row) { //표시할 데이터 렌더링
				var protoRecGame = row.PROTO_RECORD_GAME ? " (" + row.PROTO_RECORD_GAME + ")" : "";
				var uri = '/main/mainPage/gamebuy/winrstDetl'+('Y' == 'Y' ? 'IFR' : '')+'.do?' + "gmId=" + row.GM_ID + "&gmTs=" + row.GM_TS;
				for(var key in pageParams) {
					uri += '&' + key + '=' + pageParams[key];
				}
				
				return "<a href='"+ uri +"'>" + row.GM_NM + " " + row.ROUND + "회차" + protoRecGame + "</a>";
			}
		},
		{
			data : "RSLT_ANNC_DTM",
			title : "발표일",
			render : function(data, type, row) { //표시할 데이터 렌더링
				if(row.GM_ID == "G101" && row.GM_TS > 2563) { //승부식은 - 표시
					return "-";
				}
				return data;
			}
		},
		{
			data : "BUY_ST_CD",
			title : "나의적중결과",
			orderable : false,
			render : function(data, type, row) {
				if(data == "1") return "적중안됨"
				else if(["2","4","5","6"].indexOf(data) > -1) return "<a href='/main/mainPage/mypage/myPurchaseWinList.do' class='fcRed textUnder'>적중됨</a>";
				else return "-";
			}
		}
	];
	//아이프레임으로 호출시 컬럼 제거
	if('Y' == 'Y') {
		cols.pop();
		onIframe();
	}
	
	var colDefs = [
		{
			targets : 0,
			createdCell : function(cell, cellData, rowData, row, col) { //셀 생성할때마다 실행되는 함수 정의
				var isWorldCup;
				if(rowData.GM_ID == 'G102') isWorldCup = betmanOnlineFront.getIsWorldCup(rowData.GM_ID, rowData.ROUND, rowData.ROUND_YEAR);
				else isWorldCup = betmanOnlineFront.getIsWorldCup(rowData.GM_ID, rowData.GM_TS);
				
				$(cell).addClass( "icoGameTd " + rowData.MCH_SPORT_CD + (isWorldCup ? 'w' : '') );
			}
		}
	];
	
	var gridParam = {
		ordering : false,
        url : "/gamebuy/winrst/inqWinrstList.do",
        columns : cols,
        columnDefs : colDefs,
        stateSave : false,
        drawCallback : function(data) {
        	$('#spn_winrstTot strong').text( betmanOnlineFront.setNumberComma(data._iRecordsTotal) );
        }
    };
	
	gridParam.pageLength = pageParams.perPage ? pageParams.perPage : 10;
	if(pageParams.curPage) {
		gridParam.displayStart = (pageParams.curPage - 1) * gridParam.pageLength;
	}
	
	var formData = function () {
		return {
			mbrNum : '',
			fromDt : $("#ica_fromDt").val(),
			endDt : $("#ica_endDt").val(),
			gmIds : $("#sbx_gmType").val(),
			perPage : pageParams.perPage,
			start : (pageParams.curPage - 1) * pageParams.perPage + 1
		};
	};
	listTable = $("#grd_winrstList").betGrid(gridParam, formData);
	
	/* list&view */
	// 페이지 변경 이벤트 추가
	$("#grd_winrstList").on('page.dt', function(){
		pageParams.curPage = listTable.page() + 1;
	    betmanOnlineFront.changeUrl(pageParams);
	});
}

/**
 * 목록조회 데이터 리로드 함수
 * @param Number 목록조회 페이지
 */
function inqWinrstList(rowLen) {
	if(rowLen && typeof rowLen === 'number') listTable.page.len(rowLen);

	listTable.ajax.reload();
}

/**
 * 목록 상단 셀렉트박스 콜백 함수
 * @param List 셀렉트박스 목록
 */
function onGmCaseInqCallback(data) {
	var slt = $('#sbx_gmCase');
	slt.empty();
	
	$('<option>').text('게임유형전체').val('').appendTo(slt);
	data.sltCodeList.forEach(function(el) {
		$('<option>').text(el.codeName).val(el.code).appendTo(slt);
	});
	
	// 게임유형 버튼 클릭 이벤트
	slt.on("selectmenuchange", function() {
		//alert("게임유형 버튼 기능 구동");
		setGmTypeSbx($(this).val(), true);
	});
	
	// 게임유형 selectBox 클릭 이벤트 - 접근성 대응. 22.01. jmcho
	$('#sbx_gmCase').change( function() {
		//alert("게임유형 셀렉트박스 변경 실행== " + $(this).val());			
		setGmTypeSbx($(this).val(), true);
	});
	
	// list&view 최초 로딩 변수 초기화 처리
	if(pageParams.sbx_gmCase) {
		slt.val(pageParams.sbx_gmCase);
	}
	
	slt.selectmenu('refresh');
}

/**
 * 목록 상단 셀렉트박스 콜백 함수
 * @param List 셀렉트박스 목록
 */
function onGmTypeInqCallback(data) {
	gmType = data.sltCodeList
	var slt = $('#sbx_gmType');
	slt.empty();
	
	$('<option>').text('게임종류전체').val('').appendTo(slt);
	gmType.forEach(function(el) {
		$('<option>').text(el.codeName).val(el.gmId).appendTo(slt);
	});
	
	// list&view 최초 로딩 변수 초기화 처리
	if(pageParams.sbx_gmType) {
		slt.val(pageParams.sbx_gmType);	
	}
	slt.selectmenu('refresh');
	
	if(pageParams.sbx_gmCase) {
		setGmTypeSbx(pageParams.sbx_gmCase);
	}
}

/**
 * 목록 상단 셀렉트박스 세팅 함수
 * @param String 1단계 셀렉트박스 value
 * @param bool 초기 value 초기화 여부
 */
function setGmTypeSbx(code, isClear) {
	var slt = $('#sbx_gmType');
	slt.empty();
	
	if(code === '') {
		$('<option>').text('게임종류전체').val('').appendTo(slt);
		gmType.forEach(function(el) {
			$('<option>').text(el.codeName).val(el.gmId).appendTo(slt);
		});
	} else {
		gmType.forEach(function(el) {
			if(el.code.indexOf(code) > -1)
				$('<option>').text(el.codeName).val(el.gmId).appendTo(slt);
		});
	}
	// list&view 최초 로딩 변수 초기화 처리
	if(!isClear && pageParams.sbx_gmType) {
		slt.val(pageParams.sbx_gmType);
	}
	
	slt.selectmenu('refresh');
}

