		return false;
	});
	
	// logout 버튼
	document.getElementById('logoutBtn').addEventListener('click', function() {
		popupClose();
		openLogoutPop();
	});
	
	var popupDialog = document.getElementById('asideletter');
	var closeBtn = document.getElementById('popupClose');
	
	popupDialog.addEventListener('keydown',  function(event) {
		if(event.key === 'Tab'){
			if(event.shiftKey){
				if(document.activeElement === popupDialog){
					closeBtn.focus();
					event.preventDefault();
				}				
			}else{
				if(document.activeElement === closeBtn){
					popupDialog.focus();
					event.preventDefault();
				}				
			}
		}
	});

}); // ready

// 건전 팝업(60분) 열기
function popupOpen(e){
	var popup = document.getElementById('asideletter');
	if(e != null ){
		//popup 닫힐때 60분 기준으로 초기화
		popupClose(); // popup 초기화
		document.getElementById('loginTime').innerHTML = '60분';
		document.getElementById('divLetter').className = 'time-letter1';
	}
	var isIE = detectIE();
	popup.style.display = 'block';
	if(!isIE){
		popup.show();	
	}	
	popup.focus();
}

// 건전팝업 닫기 
function popupClose() {
	var popup = document.getElementById('asideletter');
	var isIE = detectIE();
	if(!isIE){	
		popup.classList.add('hide');
		popup.addEventListener('animationend', function() {
			popup.close();
			popup.classList.remove('hide');
			popup.removeEventListener('animationend', arguments.callee, false);
			popup.style.display = 'none';
		}, false);
	}else{
		popup.style.display = 'none';
	}
}

