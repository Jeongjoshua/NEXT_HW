/**
 * 버튼 이벤트 부착 및 변경 함수 (상세화면 하단 공통)
 * @param Map 게임ID,게임회차 등의 게임정보
 */
function bindEvent(data) {
	var IFR = "Y" == "Y" ? "IFR" : "";
	var isIFR = "Y" == "Y" ? "&isIFR=Y" : "";
	
	$("#btn_toList").bind("click", function() {
		var uri = "/main/mainPage/gamebuy/winrstList"+IFR+".do?";
		for(var key in pageParams) {
			uri += key + '=' + pageParams[key] + '&';
		}
		location.href = uri.slice(0, -1);
	})
	if(data.GM_ID == "G102") {
		$("#btn_prevGm").hide();
		$("#btn_nextGm").hide();
		$("#btn_buyNWinrst").hide();
		return;
	}
	$("#btn_prevGm").unbind("click");
	$("#btn_nextGm").unbind("click");
	if(data.PREV_GM_TS) {
		$("#btn_prevGm").bind("click", function() {
			var uri = "/main/mainPage/gamebuy/winrstDetl"+IFR+".do?gmId=" + data.GM_ID + "&gmTs=" + data.PREV_GM_TS;
			for(var key in pageParams) {
				uri += '&' + key + '=' + pageParams[key];
			}
			location.href = uri;
		});
		$("#btn_prevGm").attr("disabled", false);
	} else {
		$("#btn_prevGm").attr("disabled", true);
	}
	if(data.NEXT_GM_TS) {
		$("#btn_nextGm").bind("click", function() {
			var uri = "/main/mainPage/gamebuy/winrstDetl"+IFR+".do?gmId=" + data.GM_ID + "&gmTs=" + data.NEXT_GM_TS;
			for(var key in pageParams) {
				uri += '&' + key + '=' + pageParams[key];
			}
			location.href = uri;
		});
		$("#btn_nextGm").attr("disabled", false);
	} else {
		$("#btn_nextGm").attr("disabled", true);
	}
	
	$("#btn_buyNWinrst").bind("click", function() {
		if(!isLogin) {
			openLoginPopMark("/main/mainPage/mypage/myPurchaseWinList.do");
		} else {
			location.href = "/main/mainPage/mypage/myPurchaseWinList.do";
		}
	});
}

/**
 * 코드값->밸류값 리턴함수
 * @param List<Map> 코드목록, Object 코드값
 * @return Object 밸류값
 */
function getCdVal(codeList, code) {
	var i = codeList.length;
	while(i--) {
		if(codeList[i].code == code) {
			return codeList[i].value;
		}
	}
	return "-";
}
 
/**
 * Object 안 숫자형식 데이터 천단위 컴마찍기
 * @param Object 
 * @return Object
 */
function setComma(obj) {
	var result = $.extend({}, obj);
	for(var key in result)
		if(result[key] && typeof result[key] == 'number')
			result[key] = betmanOnlineFront.setNumberComma(result[key]);
	return result;
}

