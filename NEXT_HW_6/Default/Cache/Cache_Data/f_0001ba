/**
 * 새로운 object 생성
 * @date 2020.04.20
 * @param obj
 * @author 김슬기
 */
 function newJsonObj(obj){
	if( typeof obj == 'object' ){
		var objStr = JSON.stringify(obj);
		return JSON.parse(objStr);
	}else{
		return obj;
	}
}

/**
 * json array 정렬 (원본 데이터를 변경하지 않는다.)
 * @date 2020.04.20
 * @param dl_obj = json array
 * @param name = 정렬 기준 key
 * @author 김슬기
 */
function dlSort(dl_obj, name) {
	var newDl = newJsonObj(dl_obj);
	if(typeof newDl == 'object' && newDl.length ){
		newDl.sort(function(a,b){
			if( a[name] == b[name] ) return 0;
			return a[name] > b[name] ? 1 : -1;
		});
		return newDl;
	}else{
		return dl_obj;
	}
}

/**
 * json array 정렬 후 중복 제거 (원본 데이터를 변경하지 않는다.)
 * @date 2020.04.20
 * @param dl_obj = json array
 * @param name = 정렬 기준 key
 * @author 김슬기
 */
function dlSortUniq(dl_obj, name){
	var newDl = dlSort(dl_obj, name);
	if(typeof newDl == 'object' && newDl.length ){
		var old = '';
		for(var i=newDl.length-1; i>-1; i--){
			if(newDl[i][name] == old){
				newDl.splice(i,1);
			}else{
				old = newDl[i][name];
			}
		}
		return newDl;
	}else{
		return dl_obj;
	}
}

/**
 * 프로토 승부식 상세보기 조회조건 세팅 함수
 * @param List 적중결과
 */
function setSbxProtoVic(detlBody) {
	
	var sbxSport = dlSortUniq(detlBody, "MCH_SPORT_CD");
	var sbxLeag = dlSortUniq(detlBody, "LEAG_CD_NM");
	winrstPrtVic.sbxLeag = sbxLeag; //종목 변경시 리그 세팅용 변수
	var sbxType = dlSortUniq(detlBody, "HANDI_VAL");
	
	//스포츠 종목 조회조건 세팅
	var _sportsType = {	SC : '축구', BS : '야구', BK : '농구', VL : '배구' };
	var slt = $('#sbx_vicSport');
	slt.empty();
	
	$('<option>').text('종목전체').val('').appendTo(slt);
	for(var key in _sportsType) {
		if(sbxSport.map(function(e) { return e.MCH_SPORT_CD; }).indexOf(key) !== -1) {
			$('<option>').text(_sportsType[key]).val(key).appendTo(slt);
		}
	}
	
	// 종목선택 버튼 클릭 이벤트
	slt.on('selectmenuchange', function() { 
		//alert("종목선택 버튼 기능 구동");
		setLeagSbx(this.value); 
	});
	
	// 종목선택 selectBox 클릭 이벤트 - 접근성 대응. 22.01. jmcho
	$('#sbx_vicSport').change( function() {
		//alert("종목선택 셀렉트박스 변경 실행== " + $(this).val());			
		setLeagSbx(this.value); 	
	}); 
	
	slt.selectmenu('refresh');
	
	//대회 종류 조회조건 세팅
	setLeagSbx();
	
	//게임 유형 조회조건 세팅
	var _handiType = {	0 : '일반', 2 : '핸디캡', 5 : '홀/짝', 9 : '언더오버', 12 : '핸디캡', 13: '승1패', 14: '승5패' };
	slt = $('#sbx_vicType');
	slt.empty();
	
	$('<option>').text('게임유형전체').val('').appendTo(slt);
	for(var key in _handiType) {
		if(sbxType.map(function(e) { return e.HANDI_VAL == "12" ? "2" : e.HANDI_VAL.toString(); }).indexOf(key) !== -1) {
			$('<option>').text(_handiType[key]).val(key).appendTo(slt);
		}
	}
	slt.selectmenu('refresh');
	//검색용 컬럼 hide처리
	detlTable.columns([11,12,13,14]).visible(false);
	
	//싱글 게임이 있을 경우에만 보임
	if(sglYn == "Y") {
		$("#selSglYn").show();
	}
	else {
		$("#selSglYn").hide();
	}
}

/**
 * 대회 조회조건 세팅 함수
 * @param List 적중결과
 */
function setLeagSbx(sport) {
	var sbxLeag = winrstPrtVic.sbxLeag;
	var slt = $('#sbx_vicLeag');
	slt.empty();
	
	$('<option>').text('대회전체').val('').appendTo(slt);
	$.each(sbxLeag, function(key, val){
		if(!sport || sport == val.MCH_SPORT_CD) {
			$('<option>').text(val.PR_LL_WIN_LEAG_NM).val(val.LEAG_CD_NM).appendTo(slt);
