.toto-info-pop-wrap{
    position: fixed;
    top:0;
    left: 0;
    right:0;
    bottom:0;
    display: flex;
    justify-content: center;
    align-items: center;
    display: none;
}
.toto-info-pop{
    max-width:750px;
    width:100%;
    background-color: #ffffff;
    -webkit-border-radius: 5px;
    -moz-border-radius: 5px;
    border-radius: 5px;
    box-shadow: 3px 5px 10px 3px rgba(0,0,0,.1);
    max-height: 850px;
    overflow-y: auto;
    position: relative;
}
.toto-info-pop-close{
    position: absolute;
    top:10px;
    right:10px;
    cursor: pointer;
}
.toto-info-pop-close img{
    width:20px;
}
.toto-info-body{
    padding:20px;
}
.toto-info-body ul{
    padding-left: 15px;
}
.toto-info-body ul li{
    list-style: none;
    position: relative;
    line-height: 18px;
}
.info-list:before{
    content: '';
    position: absolute;
    left: -10px;
    top: 7px;
    width: 3px;
    height: 1px;
    background-color: #777777;
    -webkit-print-color-adjust: exact;
}
.toto-info-img{
    width:100%;
}
.toto-info-img img{
    max-width: 100%;
}
.toto-info-btn-box{
    width: 100%;
