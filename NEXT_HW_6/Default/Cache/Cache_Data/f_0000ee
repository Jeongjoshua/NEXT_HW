.burgur {
    width: 25px;
    height: 2px;
    background: #333;
    position: relative;
}
.detail_burgur{
    width: 25px;
    height: 2px;
    background: #fff;
    position: relative;
}
.detail_burgur .line_1{
    display: block;
    width: 25px;
    height: 2px;
    background-color: #fff;
    bottom: -6px;
    position: absolute;
    left: 0;
    -webkit-transition: background-color .2s, -webkit-transform .3s;
    transition: background-color .2s, -webkit-transform .3s;
    transition: transform .3s, background-color .2s;
    transition: transform .3s, background-color .2s, -webkit-transform .3s;
}
.detail_burgur .line_2{
    display: block;
    width: 25px;
    height: 2px;
    background-color: #fff;
    top: -6px;
    content: '';
    position: absolute;
    left: 0;
    -webkit-transition: background-color .2s, -webkit-transform .3s;
    transition: background-color .2s, -webkit-transform .3s;
    transition: transform .3s, background-color .2s;
    transition: transform .3s, background-color .2s, -webkit-transform .3s;
}

.burgur::before {
    display: block;
    width: 25px;
    height: 2px;
    background-color: #333;
    bottom: -6px;
    content: '';
    position: absolute;
    left: 0;
    -webkit-transition: background-color .2s, -webkit-transform .3s;
    transition: background-color .2s, -webkit-transform .3s;
    transition: transform .3s, background-color .2s;
    transition: transform .3s, background-color .2s, -webkit-transform .3s;
}
.burgur::after {
    display: block;
    width: 25px;
    height: 2px;
    background-color: #333;
    top: -6px;
    content: '';
    position: absolute;
    left: 0;
    -webkit-transition: background-color .2s, -webkit-transform .3s;
    transition: background-color .2s, -webkit-transform .3s;
    transition: transform .3s, background-color .2s;
    transition: transform .3s, background-color .2s, -webkit-transform .3s;
}
.burgur.on::after {
    -webkit-transform: translateY(5px) rotate(135deg);
    -ms-transform: translateY(5px) rotate(135deg);
    transform: translateY(5px) rotate(135deg);
}
.burgur.on::before {
    -webkit-transform: translateY(-7px) rotate(-135deg);
    -ms-transform: translateY(-7px) rotate(-135deg);
    transform: translateY(-7px) rotate(-135deg);
}
.burgur.on {
    background-color: transparent;
}
