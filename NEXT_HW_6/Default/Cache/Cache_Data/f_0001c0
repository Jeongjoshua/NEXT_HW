<script>
    $(function(){
        var popupLength = $(".popup_box").length;
        if(popupLength > 0){
            var obj = $(".container").offset();
            for(var i=0;i<popupLength;i++){
                var cnt = i + 1;
                var popLeft = (i * 300) + obj.left + (i * 20);
                var popTarget = $("#popup_box"+cnt);
                if(popTarget.hasClass('p_default')){
                    popTarget.css('left',popLeft);
                }
            }
        }
        $(".popup_desc_box").click(function(){
            var popIdx = $(this).attr('data-pop');
            var cookieName = "pop"+popIdx;
            $(this).parents('div.popup_box').css('display','none');
            setCookie(cookieName,'1',1);
        });
        $(".popup_box").draggable();
        $(".top_head_label").click(function(){
            $(".main_top_head").css('display','none');
            $(".mobile_menu_box").removeClass('head_on');
            setCookie('head_top','1',1);
        });
        $(".top_head_close").click(function(){
            $(".main_top_head").css('display','none');
            $(".mobile_menu_box").removeClass('head_on');
        });
        function setCookie(cookie_name, value, days) {
            var exdate = new Date();
            exdate.setDate(exdate.getDate() + days);
            // 설정 일수만큼 현재시간에 만료값으로 지정

            var cookie_value = escape(value) + ((days == null) ? '' : ';    expires=' + exdate.toUTCString());
            document.cookie = cookie_name + '=' + cookie_value;
        }
        $(".popup_close_btn").click(function(){
            $(this).parents('.popup_box').css('display','none');
        });
    });
</script>
