/* layout */
.wrap{overflow-x: hidden; position:relative;min-width:1160px; width:100%; height:100%;}

.header {position: relative;min-width: 1080px;height: 82px;border-bottom: 3px solid #c4113c;background-color: #fff;z-index: 50;}

.headerLogo {position:relative;width: 1080px;margin: 0 auto;z-index: 118;}
.headerLogo h1 {position:absolute;left: 0;top: 40px;}
.headerLogo h1 a {display: block;}
.headerLogo h1 a img {display: block;}

.headerTop {position: relative;background-color: #fff;padding-bottom: 1px;z-index: 103;}
.headerTop:after {content: "";position: absolute;left: 0;right: 0;top: 28px;display: block;height: 1px;background-color: #eee;}
.headerTop .headState {position: relative;text-align: right;width: 1080px;min-width: 1080px;height: 28px;margin: 0 auto;font-size: 0;}
.headerTop .headState > [class*='stateLog'] {overflow: hidden;display: inline-block;vertical-align: top;}
.headerTop .headState > [class*='stateLog'] > * {float: left;}
.headerTop .headState > [class*='stateLog'] .hMenu {overflow: hidden;}
.headerTop .headState > [class*='stateLog'] .hMenu li {float: left;}
.headerTop .headState > [class*='stateLog'] .hMenu li a {display: block;line-height: 28px;padding: 0 10px;font-size: 12px;color: #555;}
.headerTop .headState > [class*='stateLog'] .hState {overflow: hidden;position: relative;padding-right: 28px;}
.headerTop .headState > [class*='stateLog'] .hState:after {content: "";position: absolute;right: 10px;top: 50%;display: block;width: 1px;height: 12px;margin-top: -6px;background-color: #eee;}
.headerTop .headState > [class*='stateLog'] .hState li {float: left;}
.headerTop .headState > [class*='stateLog'] .hState .name {position: relative;line-height:28px;padding-left: 17px;font-size: 12px;color: #555;}
.headerTop .headState > [class*='stateLog'] .hState .name:after {content: "";position: absolute;left: 0;top: 8px;display: block;width: 12px;height: 12px;background: url(/images/comm/gnb_bg.png) no-repeat;}
.headerTop .headState > [class*='stateLog'] .hState .name.state01:after {}/* 매우건전 */
.headerTop .headState > [class*='stateLog'] .hState .name.state02:after {background-position: -12px top;}/* 건전 */
.headerTop .headState > [class*='stateLog'] .hState .name.state03:after {background-position: -24px top;}/* 주의 */
.headerTop .headState > [class*='stateLog'] .hState .name.state04:after {background: none;}/* 미설정 */
.headerTop .headState > [class*='stateLog'] .hState .name strong {display: inline-block;vertical-align: top;line-height:27px;font-weight: 700;color: #222;}
.headerTop .headState > [class*='stateLog'] .time {position: relative;line-height: 27px;padding-left: 17px;margin-left: 20px;font-size: 12px;color: #222;}
.headerTop .headState > [class*='stateLog'] .time:after {content: "";position: absolute;left: 0;top: 8px;display: block;width: 12px;height: 12px;background: url(/images/comm/gnb_bg.png) no-repeat -12px -12px;}
.headerTop .headState > [class*='stateLog'] .inform {margin-left: 15px;}
.headerTop .headState > [class*='stateLog'] .inform a {position: relative;display: block;width: 25px;height: 28px;}
.headerTop .headState > [class*='stateLog'] .inform a:after {content: "";position: absolute;left: 5px;top: 8px;display: block;width: 15px;height: 14px;background: url(/images/comm/gnb_bg.png) no-repeat left -24px;z-index: 1;}
.headerTop .headState > [class*='stateLog'] .inform a .mark {position: absolute;left: 13px;top: 4px;display: block;width: 8px;height: 8px;border: 1px solid #fff;border-radius: 4px;background-color: #c4113c;z-index: 2;}
.headerTop .headState > [class*='stateLog'] .shopping {}
.headerTop .headState > [class*='stateLog'] .shopping a {position: relative;display: block;width: 25px;height: 28px;}
.headerTop .headState > [class*='stateLog'] .shopping a:after {content: "";position: absolute;left: 5px;top: 8px;display: block;width: 15px;height: 14px;background: url(/images/comm/gnb_bg.png) no-repeat -15px -24px;z-index: 1;}
.headerTop .headState > [class*='stateLog'] .shopping a .number {position: absolute;left: 12px;top: 3px;display: block;text-align: center;min-width: 12px;height: 12px;line-height: 12px;border-radius: 6px;font-size: 8px;font-family:'Roboto', sans-serif;color: #fff;background-color: #c4113c;z-index: 2;padding: 0 3px 0 2px;}

.headerMenu {overflow: hidden;position: absolute;left: 0;right: 0;top: 29px;background-color: #fff;z-index: 17;}
.headerMenu:before {content: "";position: absolute;left: 0;right: 0;top: 50px;display: none;height: 1px;background-color: #ddd;}
.headerMenu:after {content: "";position: absolute;left: 0;right: 0;bottom: 0;display: none;height: 1px;background-color: #c4113c;}
.headerMenu .nav {width: 1080px;margin: 0 auto;}
.headerMenu .nav .navList { overflow: hidden;width: 800px;margin: 0 126px 0 154px; }
.headerMenu .nav .navList > li {float: left;text-align: center;}
.headerMenu .nav .navList > li > a {position: relative;display: block;width: 160px;height: 50px;line-height: 50px;font-size: 18px;font-weight: 800;color: #222;}
.headerMenu .nav .navList > li > ul {display: none;height: 350px;padding: 11px 0;border-right: 1px solid #ddd;}
.headerMenu .nav .navList > li:first-child > ul {border-left: 1px solid #ddd;}
.headerMenu .nav .navList > li > ul > li > a {display: block;height: 33px;line-height: 33px;font-size: 14px;color: #555;}

.headerMenu.gnbOn {box-shadow:0 0 6px 0 #555;z-index: 102;}
.headerMenu.gnbOn:before, 
.headerMenu.gnbOn:after {display: block;}
.headerMenu .nav .navList > li.depthOn > a {color: #c4113c;}
.headerMenu .nav .navList > li.depthOn > a:after {content: "";position: absolute;left: -1px;right: 0;bottom: -1px;display: block;height: 2px;background-color: #c4113c;}
.headerMenu .nav .navList > li.depthOn:first-child > a:after {left: 0;}
.headerMenu .nav .navList > li.depthOn > ul {background-color: #f8f8f8;}
.headerMenu .nav .navList > li > ul > li.menuOn > a {font-weight: 700;color: #222;}

.headerSub {position: relative;width: 1080px;margin: 0 auto;z-index: 999;}
.headerSub > ul {overflow: hidden;position: absolute;right: 0;top: 11px;}
.headerSub > ul li {float: left;}
.headerSub > ul li + li {margin-left: 5px;}
.headerSub > ul li a {position: relative;display: block;width: 28px;height: 28px;border: 1px solid #bbb;background-color: #fff;}
.headerSub > ul li a:after {content: "";position: absolute;display: block;}
.headerSub > ul .useGuide a:after {left: 50%;top: 7px;width: 15px;height: 12px;margin-left: -7px;background:url(/images/comm/gnb_bg.png) no-repeat left -38px;}
.headerSub > ul .useGuide a.active {border-color: #222;background-color: #222;}
.headerSub > ul .useGuide a.active:after {display: none;}
.headerSub > ul .useGuide a.active span {display: block;text-align: center;height: 26px;line-height: 26px;font-size: 12px;color: #fff;}

.headerSub > ul .useGuide2 a:after {left: 20%;top: 7px;width: 15px;height: 12px;margin-left: -7px;background:url(/images/comm/gnb_bg2.png) no-repeat left 0px;}
.headerSub > ul .useGuide2 a:focus, span.use {text-align:center; display: block; margin-left: 15px; width:70px;line-height: 26px;font-size: 12px;color: #000;}
.headerSub > ul .useGuide2 a:hover {border-color: #222;background-color: #222;}
.headerSub > ul .useGuide2 a:hover:after {background-position:  -0px -12px;}
.headerSub > ul .useGuide2 a:hover span.use {text-align:center; display: block; margin-left: 15px;width:70px;line-height: 26px;font-size: 12px;color: #fff;}


.headerSub > ul .totalMenu a:after {left: 50%;top: 8px;width: 15px;height: 11px;margin-left: -7px;background:url(/images/comm/gnb_bg.png) no-repeat -15px -38px;}
.headerSub > ul .totalMenu a:focus, 
.headerSub > ul .totalMenu a:hover {border-color: #222;background-color: #222;}
.headerSub > ul .totalMenu a:focus:after, 
.headerSub > ul .totalMenu a:hover:after {background-position: -30px -38px;}

