.totalMenuArea {display: none;z-index: 30;position: relative;position: fixed;left: 0;top: 0;right: 0;bottom: 0;overflow-y: auto;background: rgba(0, 0, 0, 0.7);text-align: center;padding: 10px 0px;}
.totalMenuArea:after {content: "";/* position: fixed; *//* left: 0; *//* right: 0; *//* top: 0; *//* bottom: 0; */display: inline-block;/* background-color: rgba(0, 0, 0, 0.7); */z-index: 100;vertical-align: middle;height: 100%;width: 10px;}
.totalMenuArea .areaInner {position: relative;/* left: 50%; *//* top: 52px; */width: 1040px;/* margin-left: -540px; *//* padding-left: 14px; */z-index: 101;display: inline-block;vertical-align: middle;text-align: left;}
.totalMenuArea .areaInner:after {content: "";position: absolute;left: 0px;bottom: 52px;width: 124px;height: 176px;background: url(/images/comm/gnb_bg.png) no-repeat left bottom;}
.totalMenuArea .depth01 {position: relative;overflow: hidden;display: inline-block;vertical-align: top;padding: 20px;background-color: #fff;/* overflow: auto; *//* height: 570px; */}
.totalMenuArea .depth01 > li {float: left;width: 158px;height: 730px;margin-left: -1px;border: 1px solid #ddd;}
.totalMenuArea .depth01 > li:first-child {height: auto;margin-left: 0px;}
.totalMenuArea .depth01 > li[class*='fix0'] {position: absolute;bottom: 20px;height: 365px;}
.totalMenuArea .depth01 > li.fix01 {left: 339px;}
.totalMenuArea .depth01 > li.fix02 {left: 498px;}
.totalMenuArea .depth01 > li:nth-child(7),
.totalMenuArea .depth01 > li:nth-child(8){position: absolute;bottom: 20px;height: 365px;}
.totalMenuArea .depth01 > li:nth-child(7){left: 335px;}
.totalMenuArea .depth01 > li:nth-child(8){left: 492px;}

.totalMenuArea .depth01 > li > a {position: relative;display: block;text-align: center;height: 41px;line-height: 40px;border-bottom: 1px solid #ddd;font-size: 16px;font-weight: 700;color: #222;background-color: #f2f2f2;}
.totalMenuArea .depth02 {padding: 13px 19px 0;}
.totalMenuArea .depth01 > li:first-child .depth02 {padding-bottom: 21px;}
.totalMenuArea .depth02 > li {}
.totalMenuArea .depth02 > li + li {margin-top: 9px;}
.totalMenuArea .depth02 > li > a {display: inline-block;vertical-align: top;line-height: 21px;font-size: 13px;color: #222;}
.totalMenuArea .depth03 {   }
.totalMenuArea .depth03 > li {position: relative;padding-left: 7px;}
.totalMenuArea .depth03 > li:after {content: "";position: absolute;left: 0;top: 11px;display: block;width: 4px;height: 1px;background-color: #555;}
.totalMenuArea .depth03 > li > a {display: inline-block;vertical-align: top;line-height: 22px;font-size: 12px;color: #555;}

.totalMenuArea .depth01 > li.depOn01 > a {color: #c4113c;}
.totalMenuArea .depth01 > li.depOn01 > a:after {content: "";position: absolute;left: 0;right: 0;bottom: -1px;display: block;height: 2px;background-color: #c4113c;}
.totalMenuArea .depth02 > li.depOn02 > a {font-weight: 700;text-decoration: underline;}
.totalMenuArea .depth03 > li.depOn03 > a {text-decoration: underline;}

.totalMenuArea .btnClose {position: absolute;right: 1px;top: 7px;display: block;width: 33px;padding-top: 29px;}
.totalMenuArea .btnClose:after {content: "";position: absolute;left: 5px;top: 3px;display: block;width: 23px;height: 23px;background: url(/images/comm/gnb_bg.png) no-repeat right -27px;}
.totalMenuArea .btnClose span {display: block;text-align: center;line-height: 11px;font-size: 9px;font-family: 'Roboto', sans-serif;color: #fff;}

