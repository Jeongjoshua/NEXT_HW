	hitRateResult : function (selector, param, list){
		var rate, participants=0, success=0; // 종합적중률, 예측참여, 적중
		
		var hasKey = param.sportType && typeof param.sportType == 'string';
		var key = hasKey? param.sportType.toLowerCase() : "total";
		
		// 차트 x축, y축 default array
		var x = ["x"]; 
		var yTotal = ["종목전체"], ySoccer = ["축구"], yBaseball = ["야구"], yVolleyball = ["배구"], yBasketball = ["농구"];
		
		for (var i in list){
			var data = list[i];
			participants += data[key + "MatchCount"];
			success += data[key + "WinCount"];
			
			var date = data.exptWinProcDt;
			var y = date.substr(0,4), m = date.substr(4,2), d = date.substr(6,2);
			var pushDate = param.seperator == "daily" ? [y,m,d].join("-") : [y,m,"01"].join("-") 
			x.push(pushDate);
			yTotal.push(data.totalRatio);
			ySoccer.push(data.scRatio);
			yBaseball.push(data.bsRatio);
			yVolleyball.push(data.vlRatio);
			yBasketball.push(data.bkRatio);
		}
		
		if(!participants || !success || isNaN(participants) || isNaN(success)){
			// 오류 처리 : 데이터를 찾을 수 없습니다?		
		}
		
		rate = (success / participants * 100 ).toFixed(2);
		rate = isNaN(rate)? 0 : rate;
		participants = betCoach.util.numFormatCase("participants", participants, ",");
		
		success = betCoach.util.numFormatCase("participants", success, ",");
		// console.log("rate ::::: ",rate,"  //// participants :::: ",participants,"   /// success :::: ",success);
		$(selector).find(".bc-hr-rate").text(rate);
		$(selector).find(".bc-hr-participants").text(participants); 
		$(selector).find(".bc-hr-success").text(success);

		var cols; 
		switch (param.sportType) {
			case "SC": cols = [x,ySoccer]; 	 	break;
			case "BS": cols = [x,yBaseball]; 	break;
			case "VL": cols = [x,yVolleyball]; 	break;
			case "BK": cols = [x,yBasketball]; 	break;
			case null: case undefined: 
